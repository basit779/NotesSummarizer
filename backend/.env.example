# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
APP_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/studysnap?schema=public

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ─── AI Providers ────────────────────────────────────────────────────────────
# You need at LEAST ONE of these. More = automatic fallback when rate limited.
# All options below have free tiers.
#
# Google AI Studio (Gemini 2.5 Pro + 2.0 Flash)
#   https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
#
# Groq (Llama 3.3 70B + 3.1 8B Instant)
#   https://console.groq.com/keys
GROQ_API_KEY=
#
# OpenRouter (DeepSeek V3 free tier + hundreds more)
#   https://openrouter.ai/keys
OPENROUTER_API_KEY=
#
# Mistral AI (Mistral Small — free tier)
#   https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=

# ─── Billing ─────────────────────────────────────────────────────────────────
# mock = in-dev upgrade flow, flips user.plan to PRO without real payment.
# live = real Stripe checkout (requires STRIPE_* vars below).
BILLING_MODE=mock

# Only required when BILLING_MODE=live
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
STRIPE_SUCCESS_URL=http://localhost:5173/billing?success=1
STRIPE_CANCEL_URL=http://localhost:5173/billing?canceled=1

# ─── Limits ──────────────────────────────────────────────────────────────────
FREE_DAILY_UPLOAD_LIMIT=3
MAX_UPLOAD_MB=15
