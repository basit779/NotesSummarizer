generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PRO
}

enum UsageAction {
  UPLOAD
  PROCESS
}

model User {
  id               String         @id @default(cuid())
  email            String         @unique
  passwordHash     String
  name             String
  plan             Plan           @default(FREE)
  stripeCustomerId String?        @unique
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  subscription     Subscription?
  files            UploadedFile[]
  results          ProcessingResult[]
  usage            UsageLog[]
  chatMessages     ChatMessage[]
}

model Subscription {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String   @unique
  priceId              String
  status               String
  currentPeriodEnd     DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model UploadedFile {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  filename       String
  storagePath    String   // in Next/Vercel version: stays empty or "memory://" — kept for schema parity
  sizeBytes      Int
  mimeType       String
  pageCount      Int?
  contentHash    String?  // sha256 of uploaded bytes — used to dedup re-uploads of the same PDF and reuse cached ProcessingResult
  processingAt   DateTime? // set when /process starts; cleared on success/fail. Idempotency lock.
  createdAt      DateTime @default(now())

  result         ProcessingResult?

  @@index([userId, createdAt])
  @@index([userId, contentHash])
}

model ProcessingResult {
  id             String       @id @default(cuid())
  fileId         String       @unique
  file           UploadedFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  summary        String       @db.Text
  keyPoints      Json
  definitions    Json
  examQuestions  Json
  flashcards     Json
  model          String
  tokensUsed     Int?
  /// Non-null when generation fell through primary Gemini to a fallback provider.
  /// Stores the provider id that actually served the pack (e.g. "mistral-small",
  /// "openrouter-free"). Null = primary Gemini succeeded clean.
  fallbackUsed   String?
  createdAt      DateTime     @default(now())

  chatMessages   ChatMessage[]

  @@index([userId, createdAt])
}

model ChatMessage {
  id         String           @id @default(cuid())
  resultId   String
  result     ProcessingResult @relation(fields: [resultId], references: [id], onDelete: Cascade)
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       String           // 'user' | 'assistant'
  content    String           @db.Text
  createdAt  DateTime         @default(now())

  @@index([resultId, createdAt])
}

model UsageLog {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    UsageAction
  createdAt DateTime    @default(now())

  @@index([userId, action, createdAt])
}

/// Cross-user PDF hash cache. Key = sha256 of uploaded bytes. On hit we reuse
/// the stored AI pack instead of re-running providers. Standalone (no user rel)
/// by design — the same content hashed by any user maps to the same pack.
model PdfCache {
  id            String   @id @default(cuid())
  contentHash   String   @unique
  generatedPack Json
  pageCount     Int?
  hitCount      Int      @default(0)
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  @@index([expiresAt])
  @@map("pdf_cache")
}
