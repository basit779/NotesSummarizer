# ─── Database ────────────────────────────────────────────────────────────────
# Local: use docker-compose from parent repo (docker compose up -d)
# Prod (Vercel): use Neon free tier (https://neon.tech) — no credit card needed
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/studysnap?schema=public

# ─── Auth ────────────────────────────────────────────────────────────────────
# REQUIRED IN PRODUCTION: fixed random string, 32+ bytes. Example to generate:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# If this changes between deploys, ALL user sessions are invalidated (auto-logout).
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ─── AI Providers (need at least ONE) ────────────────────────────────────────
# Google AI Studio — Gemini 2.5 Pro + 2.0 Flash (recommended)
#   https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Groq — Llama 3.3 70B + 3.1 8B Instant (very fast, good fallback)
#   https://console.groq.com/keys
GROQ_API_KEY=

# OpenRouter — DeepSeek V3 free + hundreds more
#   https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Mistral — Mistral Small
#   https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=

# GitHub Models — free fallback (uses your GitHub PAT)
# GITHUB_MODELS_TOKEN=

# ─── Email (password reset) ──────────────────────────────────────────────────
# REQUIRED IN PRODUCTION for working "forgot password" flow.
# Free tier: 3,000 emails/month, no card needed. https://resend.com/api-keys
# The default RESEND_FROM works out-of-the-box without domain verification.
RESEND_API_KEY=
RESEND_FROM=StudySnap <onboarding@resend.dev>

# ─── Billing ─────────────────────────────────────────────────────────────────
# mock = dev mode, no real payments (upgrade flow flips user.plan to PRO)
# live = real Stripe (fill the STRIPE_* vars below)
BILLING_MODE=mock

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
# URLs are auto-computed from NEXT_PUBLIC_APP_URL at runtime

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Limits ──────────────────────────────────────────────────────────────────
FREE_DAILY_UPLOAD_LIMIT=10
MAX_UPLOAD_MB=15
